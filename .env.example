# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=logpose-ingestion
KAFKA_TOPICS=security-alerts

# AWS SNS / SQS (use AWS_ENDPOINT_URL for LocalStack in local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:security-alerts
SQS_QUEUE_URL=http://localhost:4566/000000000000/logpose-alerts

# GCP Pub/Sub (set PUBSUB_EMULATOR_HOST for local emulator)
PUBSUB_PROJECT_ID=logpose-dev
PUBSUB_SUBSCRIPTION_ID=security-alerts-sub
PUBSUB_EMULATOR_HOST=localhost:8085
